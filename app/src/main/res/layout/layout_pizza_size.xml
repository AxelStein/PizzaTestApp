<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.wear.widget.CurvedTextView
        style="@style/TextBody"
        android:textColor="@color/active"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="-10dp"
        android:text="@string/product_details_hint_scale"
        android:layout_width="match_parent"
        android:layout_height="120dp"/>

    <ImageView
        android:id="@+id/imageForScale"
        app:layout_constraintWidth_percent="0.2587"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:rotation="180"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/fabSizeSmall"
        style="@style/Fab.PizzaSize"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="50dp"
        app:layout_constraintBottom_toBottomOf="@id/fabSizeMedium"
        app:layout_constraintEnd_toStartOf="@id/fabSizeMedium"
        android:text="@string/size_small"/>

    <TextView
        android:id="@+id/fabSizeMedium"
        style="@style/Fab.PizzaSize"
        android:layout_marginTop="-20dp"
        app:layout_constraintTop_toBottomOf="@id/imageForScale"
        app:layout_constraintEnd_toEndOf="@id/imageForScale"
        app:layout_constraintStart_toStartOf="@id/imageForScale"
        android:text="@string/size_medium"/>

    <TextView
        android:layout_marginStart="50dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="@id/fabSizeMedium"
        app:layout_constraintStart_toEndOf="@id/fabSizeMedium"
        android:id="@+id/fabSizeLarge"
        style="@style/Fab.PizzaSize"
        android:text="@string/size_large"/>

</androidx.constraintlayout.widget.ConstraintLayout>