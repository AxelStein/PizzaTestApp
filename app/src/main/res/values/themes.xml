<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.PizzaTestApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="android:windowBackground">@color/window_background</item>
    </style>

    <style name="Theme.PizzaTestApp" parent="Base.Theme.PizzaTestApp" />

    <style name="Fab">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/fab</item>
        <item name="android:elevation">4dp</item>
        <item name="android:tint">@color/active</item>
        <item name="android:scaleType">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="TextHeader1">
        <item name="android:fontFamily">@font/figtree_light</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/active</item>
    </style>

    <style name="TextHeader2">
        <item name="android:fontFamily">@font/figtree_semi_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/active</item>
    </style>

    <style name="TextHeader3">
        <item name="android:fontFamily">@font/figtree_bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">18sp</item>
        <item name="android:textColor">@color/active</item>
    </style>

    <style name="TextCaption">
        <item name="android:fontFamily">@font/figtree_regular</item>
        <item name="android:textSize">10sp</item>
        <item name="android:lineHeight">12sp</item>
        <item name="android:textColor">@color/base_text</item>
    </style>

    <style name="TextBody">
        <item name="android:fontFamily">@font/figtree_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/base_text</item>
    </style>

    <style name="TextProductDescription">
        <item name="android:fontFamily">@font/figtree_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textColor">@color/active</item>
    </style>

    <style name="TextQuantity">
        <item name="android:fontFamily">@font/figtree_extra_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/active</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Fab.PizzaSize">
        <item name="android:background">@drawable/fab_pizza_size</item>
        <item name="android:fontFamily">@font/figtree_semi_bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/fab_pizza_size_label</item>
    </style>

    <style name="PrimaryButton" parent="TextQuantity">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/primary_button</item>
        <item name="android:textColor">#fff</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingRight">18dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>